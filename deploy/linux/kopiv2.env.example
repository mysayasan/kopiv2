# Runtime
ENVIRONMENT=dev
SERVER_HOSTNAMES=*
SERVER_PORTS=3000
SERVER_ENABLE_TLS=false
SERVER_ENABLE_NON_TLS=true
# Legacy compatibility:
# SERVER_ADDR=:3000
# SERVER_USE_TLS=false

# Security
JWT_SECRET=replace-with-strong-secret
GOOGLE_CLIENT_SECRET=replace-with-google-secret

# Database
DB_ENGINE=postgres

# Cache
CACHE_PROVIDER=redis
CACHE_TTL_SECONDS=30
CACHE_KEY_PREFIX=kopiv2
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=Simpnify@123
REDIS_DB=0
REDIS_USE_TLS=false
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_OPERATION_TIMEOUT_MS=2000

# Optional: override config-backed values if needed in future
# GOOGLE_CLIENT_ID=
# GOOGLE_REDIRECT_URL=
