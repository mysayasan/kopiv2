  "fileStorage": {
    "path": "./uploads",
    "cleanup": {
      "enabled": true,
      "frequencySeconds": 60,
      "batchSize": 100
    }
  },
  "cache": {
    "provider": "redis",
    "ttlSeconds": 30,
    "keyPrefix": "kopiv2",
    "redis": {
      "address": "localhost:6379",
      "password": "Simpnify@123",
      "db": 0,
      "useTls": false,
      "connectTimeoutMs": 2000,
      "operationTimeoutMs": 2000
    }
  },
  "rateLimit": {
    "enabled": true,
    "endpointCacheTtlSeconds": 30,
    "defaultWindowSeconds": 60,
    "devOnly": {
      "enabled": true,
      "requests": 300,
      "windowSeconds": 60
    },
    "authOnly": {
      "enabled": true,
      "requests": 120,
      "windowSeconds": 60
    },
    "public": {
      "enabled": true,
      "requests": 30,
      "windowSeconds": 60
    }
  },
  "transaction": {
    "lockProvider": "redis",
    "lockWaitTimeoutMs": 30000,
    "lockLeaseMs": 10000,
    "operationTimeoutMs": 30000,
    "stuckTimeoutMs": 30000,
    "jobWorkerEnabled": true,
    "jobWorkerFrequencySeconds": 5,
    "maxAttempts": 3
  },
  "logging": {
    "enabled": true,
    "path": "./logs/mymatasan.log",
    "maxLineBytes": 8192,
    "cleanup": {
      "enabled": false,
      "maxRetentionDays": 90,
      "frequencyMinutes": 60
    }
  },
  "apiLog": {
    "cleanup": {
      "enabled": false,
      "maxRetentionDays": 90,
      "frequencyMinutes": 60
    }
  },
  "telemetry": {
    "enabled": true,
    "prometheus": {
      "enabled": true,
      "metricsPath": "/metrics",
      "apiDurationThresholdMs": 1000
    }
  },
  "tls": {
    "certPath": "./certs/cert.pem",
    "keyPath": "./certs/key.pem"
  },
  "server": {
    "hostnames": ["*"],
    "tlsPorts": [],
    "nonTlsPorts": [3000]
  },
  "allowOrigins": "*",
  "bootstrap": {
    "enabled": true,
    "autoCreateDatabase": true,
    "autoCreateSchema": true,
    "autoMigrate": true,
    "autoSeed": true,
    "allowReset": false,
    "setupPath": "/setup",
    "seedStatements": []
  },
  "db": {
    "engine": "postgres",
    "host": "localhost",
    "port": 5432,
    "user": "postgres",
    "password": "postgres",
    "db_name": "mymatasandb",
    "ssl_mode": "disable"
  }
}
